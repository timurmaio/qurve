{
  "name": "charting",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter qurve build && react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "test": "pnpm --filter qurve test",
    "typecheck": "pnpm --filter qurve build && pnpm --filter qurve typecheck && react-router typegen && tsc",
    "verify": "pnpm test && pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "@react-router/node": "^7.13.0",
    "@react-router/serve": "^7.13.0",
    "isbot": "^5.1.35",
    "qurve": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@react-router/dev": "^7.13.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react-router-devtools": "^6.2.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "packageManager": "pnpm@10.30.3"
}
